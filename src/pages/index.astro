  <div
    class="section bg-(--card-bg) rounded-sm px-8 py-6 mt-30"
  >
    <span id="about"></span>
    <p class="text-base text-gray-800 dark:text-white">
      Hello! I am <span class="text-yellow-500 dark:text-yellow-200 inline">
        Chung Nghia
      </span>, an aspiring developer. Constantly learning and creating projects.
    </p>
    <div class="mt-4 flex flex-wrap gap-2 relative">
      {
        config.links.length > 1 &&
          config.links.map((item) => (
            <a
              aria-label={item.name}
              href={item.url}
              target="_blank"
              class="flex items-center p-2 text-blue-800 dark:text-blue-100 rounded-sm bg-(--header-btn-bg) hover:bg-(--header-btn-bg-hover) active:scale-95 transition-all"
            >
              <Icon name={item.icon} class="text-base" />
              <span class="ms-2">{item.name}</span>
            </a>
          ))
      }
    </div>
  </div>

  <div
    class="section bg-(--card-bg) rounded-sm px-8 py-6 mt-8"
  >
    <span id="projects"></span>
    <h1
      class="w-full text-2xl mb-8 font-bold ps-4 border-s-4 border-blue-500 text-gray-900 dark:text-white/90"
    >
      PROJECTS
    </h1>

    <ol class="relative space-y-8 border-s-[3px] border-dashed border-gray-800 dark:border-gray-700">
      {
        projectConfig.groups.map((group) => (
          <>
            {/* <li class="mb-6 ms-8">
              <div class="absolute w-6 h-6 bg-white rounded-full -start-3 border-4 border-blue-400 ring-6 ring-white dark:bg-(--card-bg) dark:ring-(--card-bg)" />
              <h2 class="h-6 mb-1 text-2xl font-bold leading-none text-gray-900 dark:text-white">
                {group.year}
              </h2>
            </li> */}
            {group.projects.map((project) => (
              <li class="ms-8 rounded-lg">
                <div class="absolute size-6 border-3 bg-white dark:bg-(--card-bg) border-gray-800 dark:border-gray-700 rounded-full -start-[13px]" />
                <div class="mb-3 text-lg font-bold text-gray-900 dark:text-white">
                  {project.name}
                </div>
                <ul class="flex flex-wrap mt-1.5 mb-3 gap-2">
                  {project.techStack.map((tech) => (
                    <li class="bg-blue-100 text-blue-800 text-base font-medium px-2.5 py-1 rounded-sm">
                      {tech}
                    </li>
                  ))}
                </ul>
                <div class="mt-1.5 mb-3 text-base font-bold text-gray-900 dark:text-white">
                  {project.links.map((link) => (
                    <a
                      href={link.url}
                      target="_blank"
                      class="me-2 text-blue-400 border-b border-dashed"
                    >
                      {link.name}
                    </a>
                  ))}
                </div>
                <div class="mb-3 text-base font-normal text-gray-500 dark:text-gray-400">
                  {project.description}
                </div>
                {project.imgs && project.imgs.length > 0 && (
                  <div class="carousel w-full project-photos flex gap-x-1 overflow-x-scroll pb-1 snap-x snap-mandatory">
                    {project.imgs.map(
                      (img) => (
                        <ImageWrapper
                          src={img}
                          class:list={[
                            "snap-start w-auto h-64 shrink-0 rounded-md cursor-zoom-in",
                          ]}
                        />
                      ),
                      // <img loading="lazy" src={img} alt={img || ""} class:list={["snap-start w-[calc(50%-0.5rem)] shrink-0 rounded-xl cursor-zoom-in"]} />
                    )}
                  </div>
                )}
              </li>
            ))}
          </>
        ))
      }
    </ol>
  </div>
